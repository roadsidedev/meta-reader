# =============================================================================
# Server-side secrets — NEVER use VITE_ prefix for API keys.
# VITE_ variables are compiled into the browser bundle and publicly visible.
# =============================================================================

# ElevenLabs API key for text-to-speech (used by the /api/tts/synthesize proxy)
ELEVENLABS_API_KEY=

# =============================================================================
# LLM provider for scene analysis (/api/scene/analyze)
# =============================================================================

# Which provider to use: anthropic | openai | gemini | openrouter | nvidia
# Defaults to "anthropic" when unset.
LLM_PROVIDER=anthropic

# API key for the chosen provider (required)
LLM_API_KEY=

# Model override — uses the provider default when unset.
# Examples: claude-sonnet-4-6, gpt-4o-mini, gemini-1.5-flash,
#           openai/gpt-4o-mini (openrouter), meta/llama-3.1-8b-instruct (nvidia)
LLM_MODEL=

# Legacy fallback: accepted when LLM_PROVIDER=anthropic and LLM_API_KEY is unset.
# Prefer LLM_API_KEY for new deployments.
CLAUDE_API_KEY=

# =============================================================================
# Optional configuration
# =============================================================================

# Comma-separated list of allowed CORS origins (dev server only, defaults to *)
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=

# Dev API server port (defaults to 3001)
PORT=3001
